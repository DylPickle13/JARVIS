# Copy this file to .env and fill in the secret values.
# Never commit .env.

# Required
DISCORD_BOT_TOKEN=
# Optional: server/guild id for slash-command syncing and Discord helpers.
DISCORD_GUILD_ID=

# Independent scheduled Pi jobs -> Discord output channel
# If your bot is in multiple servers, set the server/guild id before running `/discord-cron setup`.
DISCORD_CRON_GUILD_ID=
DISCORD_CRON_CHANNEL_NAME=jarvis-cron
DISCORD_CRON_CHANNEL_ID=
DISCORD_CRON_PI_MODEL=
DISCORD_CRON_TIMEOUT_SECONDS=7200
# Shared local OpenAI-compatible/oMLX server.
OMLX_BASE_URL=http://<omlx-host>:8000
OMLX_PDF_MODEL=MarkItDown

# Morning briefing runs as a direct stdout cron command; these control its optional oMLX polishing call.
BRIEFING_MODEL=Qwen3.6-35B-A3B-6bit
BRIEFING_OMLX_BASE_URL=http://<omlx-host>:8000/v1
# Comma-separated cron job names/ids whose successful output should suppress embeds.
DISCORD_CRON_SUPPRESS_EMBEDS_JOBS=briefing,ai-news

# Discord bot settings
JARVIS_LOG_LEVEL=INFO
# Optional shared bearer token for local OpenAI-compatible/oMLX endpoints.
OMLX_API_KEY=

# Operation JARVIS Spotify/Cast control.
# SPOTIFY_SP_DC/SPOTIFY_SP_KEY are optional open.spotify.com cookies that let JARVIS
# wake idle Google Cast Spotify targets before sending Spotify Connect playback.
OPERATION_JARVIS_CAST_DEVICE=tv
OPERATION_JARVIS_CAST_TV_NAME=<tv-cast-friendly-name>
OPERATION_JARVIS_CAST_TV_HOST=<tv-cast-host>
OPERATION_JARVIS_CAST_SPEAKERS_NAME=<speaker-cast-friendly-name>
OPERATION_JARVIS_CAST_SPEAKERS_HOST=<speaker-cast-host>
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
SPOTIFY_SP_DC=
SPOTIFY_SP_KEY=
DISCORD_TARGET_CHANNEL_NAMES=jarvis-chat
DISCORD_STREAM_EDIT_INTERVAL_SECONDS=2
DISCORD_TOOL_HEARTBEAT_SECONDS=45
DISCORD_IMAGE_ATTACHMENT_MAX_BYTES=20971520
# Comma-separated Discord user IDs automatically added to newly created bot/cron threads.
# Optional query fallback searches server members by display name.
DISCORD_AUTO_THREAD_MEMBER_IDS=
DISCORD_AUTO_THREAD_MEMBER_QUERY=
# Discord mobile/native voice messages (.ogg/Opus attachments) -> oMLX ASR -> current Pi session.
DISCORD_VOICE_MESSAGE_ASR_ENABLED=1
DISCORD_VOICE_MESSAGE_ASR_BASE_URL=http://<asr-host>:8000/v1
DISCORD_VOICE_MESSAGE_ASR_MODEL=mlx-community/whisper-large-v3-turbo-asr-4bit
DISCORD_VOICE_MESSAGE_ASR_LANGUAGE=en
DISCORD_VOICE_MESSAGE_ASR_TIMEOUT_SECONDS=120
DISCORD_VOICE_MESSAGE_ASR_RETRIES=2
DISCORD_VOICE_MESSAGE_ASR_RETRY_BACKOFF_SECONDS=0.75
DISCORD_VOICE_MESSAGE_MAX_BYTES=26214400

# Operation JARVIS dashboard/event bridge.
# Commands stay locked unless both enable flag and write token are set on the dashboard server.
JARVIS_DASHBOARD_URL=http://127.0.0.1:8787
JARVIS_DASHBOARD_EMIT_EVENTS=1
JARVIS_DASHBOARD_CAMERA_VISION_MODEL=Qwen3.5-2B-oQ8-mtp
OMLX_VISION_MODEL=Qwen3.5-2B-oQ8-mtp
# Built-in dashboard live camera analysis. Set to 0 to disable; the browser also supports ?vision=0.
JARVIS_DASHBOARD_CAMERA_ANALYSIS_ENABLED=1
JARVIS_DASHBOARD_CAMERA_ANALYSIS_MODEL=Qwen3.5-2B-oQ8-mtp
JARVIS_DASHBOARD_CAMERA_ANALYSIS_INTERVAL_MS=2000
JARVIS_DASHBOARD_CAMERA_ANALYSIS_MAX_SIDE=640
JARVIS_DASHBOARD_CAMERA_ANALYSIS_JPEG_QUALITY=0.62
# Keep live vision frame-local by default; raise above 0 only if temporal context is desired.
JARVIS_DASHBOARD_CAMERA_ANALYSIS_CONTEXT_TURNS=0
JARVIS_ENABLE_DASHBOARD_COMMANDS=0
JARVIS_DASHBOARD_WRITE_TOKEN=
JARVIS_ENABLE_DASHBOARD_DEBUG_ENDPOINTS=0
JARVIS_DASHBOARD_AMBIENT_PULSES=0
# Dashboard oMLX tiles. Unsuffixed OMLX settings still target OMLX-16 for backwards compatibility.
JARVIS_DASHBOARD_OMLX_16_BASE_URL=http://<omlx-16-host>:8000/v1
JARVIS_DASHBOARD_OMLX_16_SSH_HOST=<omlx-16-ssh-host>
JARVIS_DASHBOARD_OMLX_64_BASE_URL=http://<omlx-64-host>:8000/v1
JARVIS_DASHBOARD_OMLX_64_SSH_HOST=<omlx-64-ssh-host>
JARVIS_DASHBOARD_OMLX_SSH_USER=<your-ssh-user>
JARVIS_DASHBOARD_OMLX_SSH_KEY=~/.ssh/jarvis_dashboard_host
# Dashboard Raspberry Pi status tile. SSH key is optional if your default SSH config/agent works.
JARVIS_DASHBOARD_RASPBERRY_PI_SSH_HOST=<raspberry-pi-host>
JARVIS_DASHBOARD_RASPBERRY_PI_SSH_USER=<raspberry-pi-user>
JARVIS_DASHBOARD_RASPBERRY_PI_SSH_KEY=~/.ssh/jarvis_dashboard_host
JARVIS_DASHBOARD_RASPBERRY_PI_ROOM_AUDIO_PATTERN=jarvis-room-audio-client.py
# Dashboard phone ADB status tile. These point at the host that owns the Android platform-tools install.
JARVIS_DASHBOARD_PHONE_ADB_SERIAL=<android-adb-serial>
JARVIS_DASHBOARD_PHONE_ADB_PATH=$HOME/.local/share/android-platform-tools/platform-tools/adb
JARVIS_DASHBOARD_PHONE_ADB_SSH_HOST=<adb-ssh-host>
JARVIS_DASHBOARD_PHONE_ADB_SSH_USER=<adb-ssh-user>
JARVIS_DASHBOARD_PHONE_ADB_SSH_KEY=~/.ssh/jarvis_dashboard_host
# Raspberry Pi room-audio endpoint tuning. Extra leading silence prevents Bluetooth/A2DP wake-up clipping.
JARVIS_ROOM_AUDIO_TTS_LEADING_SILENCE_MS=1000
JARVIS_ROOM_AUDIO_BT_PROFILE_SETTLE_SECONDS=0.45
# Keep room-audio VAD timing aligned with Discord voice.
JARVIS_ROOM_AUDIO_VAD_SILENCE_SECONDS=1.0
JARVIS_ROOM_AUDIO_VAD_MIN_UTTERANCE_SECONDS=0.5
JARVIS_ROOM_AUDIO_OPENWAKEWORD_NCPU=2
JARVIS_ROOM_AUDIO_LOCAL_WAKE_WORD_THRESHOLD=0.75
JARVIS_ROOM_AUDIO_BLUETOOTH_MAC=<bluetooth-device-mac>
JARVIS_ROOM_AUDIO_STARTUP_GREETING=1
JARVIS_ROOM_AUDIO_GREETING_ON_RECONNECT=1
JARVIS_ROOM_AUDIO_GREETING_TIMEOUT_SECONDS=30
JARVIS_ROOM_AUDIO_GREETING_ENABLED=1
JARVIS_ROOM_AUDIO_GREETING_TEXT=
# Start a fresh room-audio Pi session before the next turn after this many idle seconds. Set 0 to disable.
JARVIS_ROOM_AUDIO_PI_IDLE_NEW_SESSION_SECONDS=900
# Optional state path override. Defaults to projects/operation-jarvis/data/room_audio_greeting_state.json.
# JARVIS_ROOM_AUDIO_GREETING_STATE_PATH=projects/operation-jarvis/data/room_audio_greeting_state.json

# Live Discord voice call listener for #jarvis.
# Uses Operation JARVIS voice scripts in projects/operation-jarvis/voice, loaded by the main Discord bot process.
DISCORD_VOICE_ENABLED=1
DISCORD_VOICE_CHANNEL_NAME=jarvis
DISCORD_VOICE_STATUS_TEXT_CHANNEL_NAME=
DISCORD_VOICE_JOIN_WHEN_EMPTY=0
# Contextual join greetings: time-of-day plus "back already" if the voice channel reconnects quickly.
DISCORD_VOICE_CONTEXTUAL_GREETINGS=1
DISCORD_VOICE_GREETING_COOLDOWN_MINUTES=10
DISCORD_VOICE_GREETING_INCLUDE_STATUS=1
# Optional state path override. Defaults to projects/operation-jarvis/data/voice_greeting_state.json.
# DISCORD_VOICE_GREETING_STATE_PATH=projects/operation-jarvis/data/voice_greeting_state.json
DISCORD_VOICE_SILENCE_SECONDS=1.0
DISCORD_VOICE_MONITOR_INTERVAL_SECONDS=0.1
DISCORD_VOICE_MIN_UTTERANCE_SECONDS=0.5
DISCORD_VOICE_MAX_UTTERANCE_SECONDS=30
DISCORD_VOICE_QUEUE_MAX_SIZE=8
DISCORD_VOICE_PREPROCESS_AUDIO=1
DISCORD_VOICE_SILENCE_RMS_THRESHOLD=300
DISCORD_VOICE_MIN_VOICED_MS=200
DISCORD_VOICE_INPUT_SAMPLE_RATE=24000
DISCORD_VOICE_INPUT_MIN_SECONDS=1.0
DISCORD_VOICE_MONO_MODE=left
DISCORD_VOICE_NORMALIZE_TARGET_PEAK=16000
DISCORD_VOICE_NORMALIZE_TARGET_RMS=2500
DISCORD_VOICE_NORMALIZE_MAX_GAIN=12.0
DISCORD_VOICE_DROP_WHILE_BUSY=1
DISCORD_VOICE_SUPPRESS_RECV_CRYPTO_ERRORS=1
DISCORD_VOICE_PRELOAD_ON_JOIN=1
DISCORD_VOICE_BASE_URL=http://<voice-model-host>:8000/v1
# Optional voice-specific bearer token override. Leave commented/blank to use OMLX_API_KEY if set.
# DISCORD_VOICE_API_KEY=
DISCORD_VOICE_ASR_MODEL=mlx-community/whisper-large-v3-turbo-asr-4bit
DISCORD_VOICE_ASR_LANGUAGE=en
# Voice-only Pi LLM override for live jarvis responses; text channels still use DISCORD_PI_MODEL.
# Set empty to make voice fall back to DISCORD_PI_MODEL.
DISCORD_VOICE_PI_MODEL=omlx-64/Qwen3.6-35B-A3B-6bit
# Start a fresh live-voice Pi session before the next turn after this many idle seconds. Set 0 to disable.
DISCORD_VOICE_PI_IDLE_NEW_SESSION_SECONDS=900
# Used only by the standalone direct-oMLX voice runner; the main bot sends voice transcripts through Pi using DISCORD_VOICE_PI_MODEL/DISCORD_PI_MODEL.
DISCORD_VOICE_LLM_MODEL=Qwen3.5-9B-4bit
DISCORD_VOICE_LLM_MAX_TOKENS=120
DISCORD_VOICE_LLM_TEMPERATURE=0.4
DISCORD_VOICE_LLM_TOP_P=0.9
DISCORD_VOICE_LLM_DISABLE_THINKING=1
DISCORD_VOICE_HISTORY_TURNS=4
# Optional standalone direct-oMLX system prompt override. Main-bot live voice personality uses projects/operation-jarvis/voice/APPEND_SYSTEM.md.
# DISCORD_VOICE_SYSTEM_PROMPT="You are JARVIS in a live Discord voice call. Keep spoken replies concise."
DISCORD_VOICE_TTS_BACKEND=piper
DISCORD_VOICE_TTS_PIPER_REPO_ID=jgkawell/jarvis
DISCORD_VOICE_TTS_PIPER_QUALITY=high
DISCORD_VOICE_TTS_PIPER_LENGTH_SCALE=1.15
DISCORD_VOICE_TTS_PIPER_VOLUME=0.95
DISCORD_VOICE_TTS_PIPER_NOISE_SCALE=0.40
DISCORD_VOICE_TTS_PIPER_NOISE_W_SCALE=0.55
DISCORD_VOICE_STREAM_TTS=1
DISCORD_VOICE_STREAM_START_WORDS=0
DISCORD_VOICE_WAKE_WORD=jarvis,arvis,charvis,travis,darvish,charmavis
DISCORD_VOICE_LOCAL_WAKE_WORD_THRESHOLD=0.5
DISCORD_VOICE_STATUS_DIAGNOSTICS=1
DISCORD_VOICE_PREROLL_MS=500
DISCORD_VOICE_SILENCE_PADDING_MS=500
DISCORD_VOICE_TTS_STRIP_URLS=1
DISCORD_VOICE_TTS_STRIP_CODE=1
DISCORD_VOICE_TTS_STRIP_MARKDOWN=1
DISCORD_VOICE_TTS_STRIP_DISCORD_MARKUP=1
DISCORD_VOICE_SPEAK_PI_THINKING=0
DISCORD_VOICE_SPEAK_TOOL_CALLS=0
DISCORD_VOICE_PROCESSING_ACK_ENABLED=1
DISCORD_VOICE_PROCESSING_ACK_TEXT=Generating your response, sir.
DISCORD_VOICE_STEERING_TTS_DELAY_SECONDS=2.0
DISCORD_VOICE_TTS_MAX_SEGMENTS=0
DISCORD_VOICE_TTS_SPEED=1.0
DISCORD_VOICE_TTS_MAX_CHARS_PER_SEGMENT=220
DISCORD_VOICE_ASR_TIMEOUT_SECONDS=120
DISCORD_VOICE_LLM_TIMEOUT_SECONDS=120
DISCORD_VOICE_TTS_TIMEOUT_SECONDS=180
DISCORD_VOICE_MODEL_LOAD_TIMEOUT_SECONDS=240
DISCORD_VOICE_UNLOAD_BETWEEN_STAGES=0
DISCORD_VOICE_REQUEST_RETRIES=2
DISCORD_VOICE_REQUEST_RETRY_BACKOFF_SECONDS=0.75
DISCORD_VOICE_TTS_MAX_BYTES=104857600
DISCORD_VOICE_REQUIRE_CONFIGURED_MODELS=1
# Workout tracker thread launcher. The bot creates/updates #jarvis-helpers -> workout-tracker on startup.
DISCORD_WORKOUT_TRACKER_HELPERS_CHANNEL_NAME=jarvis-helpers
DISCORD_WORKOUT_TRACKER_THREAD_NAME=workout-tracker
DISCORD_WORKOUT_TRACKER_TIMEOUT_SECONDS=14400
DISCORD_WORKOUT_THREAD_AUTO_ARCHIVE_MINUTES=1440

# Completion-ping Pi tool. Creates/reuses #jarvis-helpers -> pings and mentions a configured user.
DISCORD_PING_GUILD_ID=
DISCORD_PING_HELPERS_CHANNEL_NAME=jarvis-helpers
DISCORD_PING_HELPERS_CHANNEL_ID=
DISCORD_PING_THREAD_NAME=pings
DISCORD_PING_THREAD_ID=
DISCORD_PING_USER_ID=
DISCORD_PING_USER_QUERY=
DISCORD_PING_THREAD_AUTO_ARCHIVE_MINUTES=1440
# Local guard for discord_ping attachments. Set 0 to disable the guard.
DISCORD_PING_ATTACHMENT_MAX_BYTES=26214400
# Local guard for the discord_send_file Pi tool. Set 0 to disable the guard.
JARVIS_DISCORD_SEND_FILE_MAX_BYTES=26214400

# Semantic search over previous Pi/JARVIS sessions through an OpenAI-compatible embeddings endpoint.
SESSION_SEARCH_EMBEDDING_BASE_URL=http://<embedding-host>:8000/v1
SESSION_SEARCH_EMBEDDING_MODEL=mlx-community/Qwen3-Embedding-8B-4bit-DWQ
SESSION_SEARCH_EMBEDDING_DIMENSIONS=
SESSION_SEARCH_EMBEDDING_BATCH_SIZE=4
SESSION_SEARCH_EMBEDDING_TIMEOUT_SECONDS=300
SESSION_SEARCH_EMBEDDING_RETRIES=3
SESSION_SEARCH_SESSIONS_DIR=.pi/runtime/local-pi-sessions
SESSION_SEARCH_DB_PATH=.pi/session-search/index.sqlite

# Project-local JARVIS long-term memory (.pi/memory/memory.sqlite).
# Set JARVIS_MEMORY_AUTO_RECALL=0 to disable prompt-time memory injection.
JARVIS_MEMORY_AUTO_RECALL=1
JARVIS_MEMORY_RECALL_LIMIT=6
JARVIS_MEMORY_RECALL_MAX_CHARS=3500

# Optional SSH Pi tool configuration. Prefer an ignored JSON file for multiple hosts.
JARVIS_SSH_HOSTS_CONFIG=.pi/ssh-hosts.json
JARVIS_SSH_DEFAULT_HOST=
JARVIS_SSH_IDENTITY_FILE=~/.ssh/id_ed25519
# Single-host fallback if JARVIS_SSH_HOSTS_CONFIG is absent.
JARVIS_SSH_HOST=
JARVIS_SSH_USER=
JARVIS_SSH_ALIAS=default
JARVIS_SSH_DEFAULT_CWD=~
JARVIS_SSH_ALLOWED_CWD_PREFIXES=~
JARVIS_SSH_HOME_DIR=
JARVIS_SSH_SHELL_TYPE=posix
# Stateful SSH PTY sessions: idle lifetime and retained terminal-output tail.
JARVIS_SSH_INTERACTIVE_IDLE_SECONDS=1800
JARVIS_SSH_INTERACTIVE_OUTPUT_BYTES=65536

# Optional Minecraft JARVIS bridge. Fill these locally if you use the minecraft_jarvis Pi tool.
JARVIS_MINECRAFT_HOST=
JARVIS_MINECRAFT_SSH_USER=
JARVIS_MINECRAFT_SSH_KEY=~/.ssh/jarvis_dashboard_host
JARVIS_MINECRAFT_FROM=player
JARVIS_MINECRAFT_TARGET=jarvis

# Operation JARVIS smart plugs (TP-Link Kasa HS103 local control).
# These can also live in projects/operation-jarvis/smart-plug/.env.
KASA_USERNAME=
KASA_PASSWORD=
# Optional extra local password if some plugs were onboarded before/after a TP-Link password change.
KASA_PASSWORD_2=
KASA_DISCOVERY_TARGET=255.255.255.255

# Optional Exa API key for web_search. If omitted, pi-web-access uses its zero-config Exa MCP fallback.
EXA_API_KEY=

# Optional Google Maps Platform API key for the one-parameter maps Pi tool.
# Enable Places API (New), Geocoding API, and Routes API on this key.
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_DEFAULT_REGION=CA
GOOGLE_MAPS_DEFAULT_LANGUAGE=en
GOOGLE_MAPS_DEFAULT_LOCATION_LABEL=Pickering, Ontario, Canada
GOOGLE_MAPS_DEFAULT_LAT=43.8384
GOOGLE_MAPS_DEFAULT_LNG=-79.0868
GOOGLE_MAPS_DEFAULT_RADIUS_METERS=25000
# Optional: lets route queries like "from home" resolve without exposing this in prompts.
# GOOGLE_MAPS_HOME_ADDRESS=

# Optional YouTube Data API key for web_search provider="youtube".
GOOGLE_API_KEY=
YOUTUBE_API_KEY=

# Optional Hugging Face / Kaggle credentials for model and dataset tooling.
HF_TOKEN=
KAGGLE_USERNAME=
KAGGLE_KEY=

# Optional Pi process settings
PI_CODING_AGENT_COMMAND=pi
PI_CODING_AGENT_ARGS=-p
PI_CODING_AGENT_PROMPT_FLAG=
PI_CODING_AGENT_WORKDIR=
PI_CODING_AGENT_RPC_TIMEOUT_SECONDS=1800
# Swap this model ID to change text/default Pi LLMs. Live voice uses DISCORD_VOICE_PI_MODEL.
DISCORD_PI_MODEL=omlx-64/Qwen3.6-35B-A3B-6bit
# Valid thinking levels: off, minimal, low, medium, high, xhigh. xhigh is the maximum used for JARVIS voice/room-audio.
DISCORD_PI_THINKING=xhigh
# Comma-separated list shown as model buttons in the /jarvis model Discord panel.
# Add every model you want to expose as a button; the panel shows up to 24.
DISCORD_PI_MODEL_OPTIONS=omlx-64/Qwen3.6-35B-A3B-6bit,omlx-64/Qwen3.6-27B-6bit,omlx/Qwen3.5-9B-4bit,openai-codex/gpt-5.5,openai-codex/gpt-5.6-sol,openai-codex/gpt-5.6-terra,openai-codex/gpt-5.6-luna,github-copilot/gpt-5.4-mini,github-copilot/gpt-5.3-codex
# Compatibility fallback routes used when an older Qwen 3.5 9B quantized model id is selected.
DISCORD_TEXT_QWEN35_9B_MODEL=omlx/Qwen3.5-9B-4bit
DISCORD_VOICE_QWEN35_9B_MODEL=omlx/Qwen3.5-9B-4bit

# Optional Python override for the google_search extension.
# Use this if system python3 is older than Python 3.10.
PI_PYTHON=.venv/bin/python

# Visible browser tool: persistent local bridge to regular Chrome.
# Start with: npm --prefix .pi/extensions/50-browser run daemon
# In Chrome 144+, enable chrome://inspect/#remote-debugging and approve the daemon once.
# PI_BROWSER_PROFILE_DIR="/Users/you/Library/Application Support/Google/Chrome"
# PI_BROWSER_PROFILE_DIRECTORY="Profile 1"
# PI_BROWSER_DAEMON_URL=http://127.0.0.1:17322
# PI_BROWSER_DAEMON_PORT=17322
# PI_BROWSER_DAEMON_TOKEN_FILE="/Users/you/.jarvis/chrome-bridge.token"
