# Copy to .env only if you do not want to use the Operation JARVIS/root .env fallback.
# Never commit .env.

# TP-Link/Kasa account credentials used for local HS103 KLAP v2 control.
KASA_USERNAME=
KASA_PASSWORD=

# Optional: extra passwords for plugs onboarded before/after a TP-Link password change.
# JARVIS will try KASA_PASSWORD first, then KASA_PASSWORD_2 ... KASA_PASSWORD_10.
# Usually the username is the same; override per slot only if needed.
KASA_USERNAME_2=
KASA_PASSWORD_2=
# KASA_USERNAME_3=
# KASA_PASSWORD_3=

# Optional compact extra-password list using the same KASA_USERNAME.
# Separate entries with || . Example: oldPassword||newPassword
KASA_EXTRA_PASSWORDS=

# Optional broadcast target if discovery misses devices.
# Example: set this to your LAN broadcast address if needed.
KASA_DISCOVERY_TARGET=255.255.255.255

# Optional comma-separated static plug map. plugs.json is preferred.
# Format: name=ip,name2=ip2
# SMART_PLUGS=lamp=<plug-ip>,fan=<plug-ip>
SMART_PLUGS=
