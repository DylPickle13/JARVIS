# Copy to .env and fill in after creating/pairing your VeSync account/device.
# This file is intentionally safe to commit; real .env is ignored.

# VeSync login used by the official VeSync app.
VESYNC_EMAIL=you@example.com
VESYNC_PASSWORD=change-me

# Pickering/Ontario defaults. VeSync treats Canada as a non-EU region.
VESYNC_COUNTRY_CODE=CA
VESYNC_TIME_ZONE=America/Toronto

# Optional: exact device name from the VeSync app. If omitted, purifierctl uses
# the first discovered air purifier. You can also pass a device name/CID/model
# as the optional CLI positional argument.
JARVIS_AIR_PURIFIER_NAME=Bedroom Air Purifier

# VeSync control writes can take more than a minute to reflect in status polling.
# The CLI waits up to this long for state convergence after a write, then marks
# accepted-but-stale writes as verification_pending instead of hard-failing.
JARVIS_AIR_PURIFIER_WRITE_WAIT_SECONDS=150
