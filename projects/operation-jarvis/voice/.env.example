# Copy this file to .env and fill in private values.
# Never commit .env.

# Required Discord bot token. You may use the same bot token as the main JARVIS bot,
# but do not run both processes with the same token at the same time unless you intend
# to split responsibilities carefully.
DISCORD_BOT_TOKEN=

# Logging
JARVIS_LOG_LEVEL=INFO

# Optional bearer token for oMLX/OpenAI-compatible endpoints if your server requires one.
OMLX_API_KEY=
# Optional voice-specific bearer token override. Leave commented/blank to use OMLX_API_KEY.
# DISCORD_VOICE_API_KEY=

# Real-time Discord voice chatbot in the voice channel named jarvis.
# Requires discord-ext-voice-recv, PyNaCl, ffmpeg, oMLX-hosted ASR/LLM models,
# and Piper for the default local JARVIS voice.
DISCORD_VOICE_ENABLED=1
DISCORD_VOICE_CHANNEL_NAME=jarvis
# Optional override for voice status messages. Leave blank to use the active voice channel chat.
DISCORD_VOICE_STATUS_TEXT_CHANNEL_NAME=
# Keep this at 0 so the listener starts when a human is present; this avoids stale empty-channel voice receive state.
DISCORD_VOICE_JOIN_WHEN_EMPTY=0
# Contextual join greetings: time-of-day plus "back already" if the voice channel reconnects quickly.
DISCORD_VOICE_CONTEXTUAL_GREETINGS=1
DISCORD_VOICE_GREETING_COOLDOWN_MINUTES=10
DISCORD_VOICE_GREETING_INCLUDE_STATUS=1
# Optional state path override. Defaults to ../data/voice_greeting_state.json.
# DISCORD_VOICE_GREETING_STATE_PATH=/path/to/JARVIS/projects/operation-jarvis/data/voice_greeting_state.json
DISCORD_VOICE_SILENCE_SECONDS=1.0
DISCORD_VOICE_MONITOR_INTERVAL_SECONDS=0.1
DISCORD_VOICE_MIN_UTTERANCE_SECONDS=0.5
DISCORD_VOICE_MAX_UTTERANCE_SECONDS=30
DISCORD_VOICE_QUEUE_MAX_SIZE=8
# Raw Discord PCM frames waiting for local wake/segmentation. 400 frames is about 8 seconds at 20ms/frame.
DISCORD_VOICE_INGEST_QUEUE_MAX_FRAMES=400
# Normalize/downsample live Discord PCM before ASR and drop likely silent/noise-only utterances.
DISCORD_VOICE_PREPROCESS_AUDIO=1
DISCORD_VOICE_SILENCE_RMS_THRESHOLD=300
DISCORD_VOICE_MIN_VOICED_MS=200
# Keep the last half-second of pre-gate audio so ASR does not lose soft first syllables.
DISCORD_VOICE_PREROLL_MS=500
DISCORD_VOICE_SILENCE_PADDING_MS=500
DISCORD_VOICE_INPUT_SAMPLE_RATE=24000
DISCORD_VOICE_INPUT_MIN_SECONDS=1.0
DISCORD_VOICE_MONO_MODE=left
DISCORD_VOICE_NORMALIZE_TARGET_PEAK=16000
DISCORD_VOICE_NORMALIZE_TARGET_RMS=2500
DISCORD_VOICE_NORMALIZE_MAX_GAIN=12.0
# Drop mic input while JARVIS is processing/speaking to avoid backlogs and feedback loops.
DISCORD_VOICE_DROP_WHILE_BUSY=1
DISCORD_VOICE_SUPPRESS_RECV_CRYPTO_ERRORS=1

# oMLX ASR plus local Piper JARVIS TTS. In the main bot, responses come from a real Pi RPC session using DISCORD_VOICE_PI_MODEL, falling back to root DISCORD_PI_MODEL if empty. DISCORD_VOICE_LLM_MODEL only applies to the standalone direct-oMLX runner.
DISCORD_VOICE_PRELOAD_ON_JOIN=1
DISCORD_VOICE_BASE_URL=http://<voice-model-host>:8000/v1
DISCORD_VOICE_ASR_MODEL=mlx-community/whisper-large-v3-turbo-asr-4bit
DISCORD_VOICE_ASR_LANGUAGE=en
DISCORD_VOICE_PI_MODEL=omlx-64/Qwen3.6-35B-A3B-6bit
DISCORD_VOICE_LLM_MODEL=Qwen3.5-9B-4bit
DISCORD_VOICE_LLM_MAX_TOKENS=120
DISCORD_VOICE_LLM_TEMPERATURE=0.4
DISCORD_VOICE_LLM_TOP_P=0.9
DISCORD_VOICE_LLM_DISABLE_THINKING=1
DISCORD_VOICE_HISTORY_TURNS=4
# Optional standalone direct-oMLX system prompt override. Main-bot live voice personality uses APPEND_SYSTEM.md.
# DISCORD_VOICE_SYSTEM_PROMPT="You are JARVIS in a live Discord voice call. Keep spoken replies concise."
# TTS backend: local Piper JARVIS model.
DISCORD_VOICE_TTS_BACKEND=piper
DISCORD_VOICE_TTS_PIPER_REPO_ID=jgkawell/jarvis
DISCORD_VOICE_TTS_PIPER_QUALITY=high
DISCORD_VOICE_TTS_PIPER_LENGTH_SCALE=1.15
DISCORD_VOICE_TTS_PIPER_VOLUME=0.95
DISCORD_VOICE_TTS_PIPER_NOISE_SCALE=0.40
DISCORD_VOICE_TTS_PIPER_NOISE_W_SCALE=0.55
# Stream sentence-sized TTS chunks while the LLM is still generating.
DISCORD_VOICE_STREAM_TTS=1
# 0 waits for the first complete sentence; set above 0 to start after that many words.
DISCORD_VOICE_STREAM_START_WORDS=0
# Generate/respond only when any comma/semicolon/pipe-separated wake word appears in the ASR transcript. Empty disables the wake-word gate.
# During an active response, another wake-word utterance steers the active Pi task and resets TTS to the post-steer answer.
DISCORD_VOICE_WAKE_WORD=jarvis,arvis,charvis,travis,darvish,charmavis
# Upstream acoustic wake-word gate. Discord PCM is checked with openWakeWord before oMLX Whisper ASR,
# so ordinary non-JARVIS speech/noise is dropped locally. The stock model phrase is "hey Jarvis".
DISCORD_VOICE_LOCAL_WAKE_WORD_ENABLED=1
# Keep this at 0 so an openWakeWord install/model problem does not silently fall back to the old always-ASR path.
DISCORD_VOICE_LOCAL_WAKE_WORD_FALLBACK_TO_ASR=0
DISCORD_VOICE_LOCAL_WAKE_WORD_ENGINE=openwakeword
DISCORD_VOICE_OPENWAKEWORD_MODEL=hey_jarvis
DISCORD_VOICE_OPENWAKEWORD_INFERENCE=onnx
DISCORD_VOICE_OPENWAKEWORD_MODEL_DIR=
DISCORD_VOICE_OPENWAKEWORD_AUTO_DOWNLOAD=1
DISCORD_VOICE_LOCAL_WAKE_WORD_THRESHOLD=0.5
DISCORD_VOICE_LOCAL_WAKE_WORD_COOLDOWN_SECONDS=2.0
DISCORD_VOICE_LOCAL_WAKE_WORD_ARM_SECONDS=8.0
DISCORD_VOICE_LOCAL_WAKE_WORD_CHUNK_MS=80
DISCORD_VOICE_LOCAL_WAKE_WORD_LOG_SCORES=0
# Keep ASR transcript wake-word confirmation after acoustic detection. Set to 1 only if you want
# "hey Jarvis" followed by a separate command inside the arm window to skip transcript confirmation.
DISCORD_VOICE_TRUST_LOCAL_WAKE_WORD=0
# Log one concise per-utterance audio/ASR diagnostic to the terminal. Set to 0 once tuning is done.
DISCORD_VOICE_STATUS_DIAGNOSTICS=1
# TTS-only sanitization: remove these silently before speech, without placeholders.
DISCORD_VOICE_TTS_STRIP_URLS=1
DISCORD_VOICE_TTS_STRIP_CODE=1
DISCORD_VOICE_TTS_STRIP_MARKDOWN=1
DISCORD_VOICE_TTS_STRIP_DISCORD_MARKUP=1
# Main-bot Pi RPC voice mode: announce tool starts, but do not speak thinking deltas.
DISCORD_VOICE_SPEAK_PI_THINKING=0
DISCORD_VOICE_SPEAK_TOOL_CALLS=0
DISCORD_VOICE_PROCESSING_ACK_ENABLED=1
DISCORD_VOICE_PROCESSING_ACK_TEXT=Generating your response, sir.
# After steering, or after cutting over a no-longer-steerable response into the next voice turn, pause briefly so stale audio can clear.
DISCORD_VOICE_STEERING_TTS_DELAY_SECONDS=2.0
DISCORD_VOICE_TTS_SPEED=1.0
DISCORD_VOICE_TTS_MAX_SEGMENTS=0
DISCORD_VOICE_TTS_MAX_CHARS_PER_SEGMENT=220
DISCORD_VOICE_ASR_TIMEOUT_SECONDS=120
DISCORD_VOICE_LLM_TIMEOUT_SECONDS=120
DISCORD_VOICE_TTS_TIMEOUT_SECONDS=180
DISCORD_VOICE_MODEL_LOAD_TIMEOUT_SECONDS=240
DISCORD_VOICE_UNLOAD_BETWEEN_STAGES=0
DISCORD_VOICE_REQUEST_RETRIES=2
DISCORD_VOICE_REQUEST_RETRY_BACKOFF_SECONDS=0.75
DISCORD_VOICE_TTS_MAX_BYTES=104857600
DISCORD_VOICE_REQUIRE_CONFIGURED_MODELS=1
